# Copy to apps/mobile/android/fastlane/.env and fill in. `.env` is gitignored;
# this `.env.example` is committed. In CI these are GitHub Actions secrets —
# see .github/RUNNERS.md.

# --- Google Play upload (supply / upload_to_play_store) ---
# Service-account JSON with "Release to testing tracks" + "Release to
# production" permission on the app.cookyourbooks Play listing. Locally, point
# this at your downloaded key file. NEVER commit the JSON (it's gitignored).
CYB_PLAY_JSON_KEY=fastlane/play-service-account.json

# --- Upload keystore ---
# Play App Signing holds the *app* signing key; this is the *upload* key we
# sign the AAB with (recoverable if lost — reset it in the Play Console).
CYB_UPLOAD_STORE_FILE=/absolute/path/to/upload-keystore.jks
CYB_UPLOAD_STORE_PASSWORD=change-me
CYB_UPLOAD_KEY_ALIAS=upload
CYB_UPLOAD_KEY_PASSWORD=change-me

# --- `fastlane release` production rollout fraction (default 0.2) ---
# PLAY_ROLLOUT=0.2

# --- Sentry (shared with iOS; optional — upload is skipped if unset) ---
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_URL=https://sentry-cyb.work.ripley.cloud
# SENTRY_ORG=cyb
# SENTRY_PROJECT_MOBILE=cyb-capacitor
