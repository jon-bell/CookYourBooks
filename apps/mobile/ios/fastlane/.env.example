# Copy to apps/mobile/ios/fastlane/.env and fill in real values.
# `.env` is gitignored — never commit it.

# App Store Connect API key — generate at:
#   https://appstoreconnect.apple.com/access/integrations/api
# Give it the "App Manager" role (or "Developer" for read-only flows).
# Download the .p8 file ONCE — Apple does not let you re-download it.
#
# These vars use a CYB_ prefix on purpose: fastlane's `match` action
# auto-detects standard env vars named `APP_STORE_CONNECT_API_KEY_*` and
# tries to use them as a JSON `api_key_path`. That conflicts with the
# explicit `api_key:` our Fastfile builds, and you'd see:
#   "Unresolved conflict between options: 'api_key_path' and 'api_key'"
# or "invalid number: '-----BEGIN' at line 1 column 1".
# Naming them out of the way avoids the whole mess.
CYB_ASC_KEY_ID=ABC123DEFG
CYB_ASC_ISSUER_ID=11111111-2222-3333-4444-555555555555
CYB_ASC_KEY_PATH=/Users/jon/.appstoreconnect/AuthKey_ABC123DEFG.p8

# Symmetric password used to encrypt the certs repo. Pick anything strong —
# you need the same value on every machine that runs `fastlane match`.
MATCH_PASSWORD=change-me

# Optional: only needed when not using the ASC API key (interactive 2FA flow).
# FASTLANE_APPLE_ID=jon@jonbell.net

# Sentry dSYM upload — required for native iOS crashes to show
# symbolicated stack traces in sentry-cyb.work.ripley.cloud. Generate
# at: Sentry → Settings → Auth Tokens (give it `project:write` scope
# for `cookyourbooks-mobile`).
# Without this token, the `beta` lane skips Sentry upload silently
# (so dev / non-CI machines don't fail).
#SENTRY_AUTH_TOKEN=sntrys_...

# Optional overrides — only set these when pointing at a different
# Sentry install or a renamed project. The defaults match our
# self-hosted setup.
#SENTRY_URL=https://sentry-cyb.work.ripley.cloud
#SENTRY_ORG=cyb
#SENTRY_PROJECT_MOBILE=cyb-capacitor
