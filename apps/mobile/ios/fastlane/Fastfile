default_platform(:ios)

# Defensively clear any standard fastlane ASC-key env vars the user might have
# set. We load the API key explicitly from CYB_ASC_* vars below — leaving the
# standard names set causes match to auto-detect them as `api_key_path`, which
# conflicts with the `api_key:` we pass explicitly.
%w[
  APP_STORE_CONNECT_API_KEY_PATH
  APP_STORE_CONNECT_API_KEY_KEY_FILEPATH
  APP_STORE_CONNECT_API_KEY_KEY
  APP_STORE_CONNECT_API_KEY_KEY_ID
  APP_STORE_CONNECT_API_KEY_ID
  APP_STORE_CONNECT_API_KEY_ISSUER_ID
  APP_STORE_CONNECT_API_KEY_DURATION
  APP_STORE_CONNECT_API_KEY_IN_HOUSE
  APP_STORE_CONNECT_API_KEY_IS_KEY_CONTENT_BASE64
  MATCH_API_KEY_PATH
  FASTLANE_API_KEY
  FASTLANE_API_KEY_PATH
].each { |k| ENV.delete(k) }

# Returns an App Store Connect API key descriptor if all three CYB_ASC_* vars
# are set, else nil. Lanes that get nil back fall through to interactive Apple
# ID 2FA. Generate the key at:
#   https://appstoreconnect.apple.com/access/integrations/api
# (role "App Manager"). Download the .p8 once — Apple won't let you re-download.
def asc_api_key_or_nil
  return nil unless ENV["CYB_ASC_KEY_ID"] \
               && ENV["CYB_ASC_ISSUER_ID"] \
               && ENV["CYB_ASC_KEY_PATH"]
  app_store_connect_api_key(
    key_id: ENV["CYB_ASC_KEY_ID"],
    issuer_id: ENV["CYB_ASC_ISSUER_ID"],
    key_filepath: ENV["CYB_ASC_KEY_PATH"],
    in_house: false
  )
end

# Same but raises if missing — lanes that *require* the key call this.
def asc_api_key
  key = asc_api_key_or_nil
  UI.user_error!(
    "ASC API key env vars are not set. Copy fastlane/.env.example to " \
    "fastlane/.env and fill in CYB_ASC_KEY_ID, CYB_ASC_ISSUER_ID, CYB_ASC_KEY_PATH."
  ) unless key
  key
end

# Login keychain password for the cyb-mac runner. Stashed by
# scripts/runner/install-launch-agents.sh under the keychain entry
# `cyb-mac-runner-keychain-unlock`. When present, we pass it to match so
# it can run `security set-key-partition-list` after importing the .p12 —
# without that, codesign trips errSecInternalComponent on every signed
# build because the freshly-imported private key has an empty ACL.
#
# Returns nil on dev machines that don't have the keychain entry; on
# those, match falls back to its interactive prompt behavior.
def runner_keychain_password
  return nil unless File.exist?("/usr/bin/security")
  pwd = `security find-generic-password -a "#{ENV['USER']}" -s cyb-mac-runner-keychain-unlock -w 2>/dev/null`.strip
  pwd.empty? ? nil : pwd
end

platform :ios do
  desc "Diagnostic: print every signing cert currently active on the Apple Developer account. Useful when match says 'reached the maximum number'."
  lane :list_certs do
    require "spaceship"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("CYB_ASC_KEY_ID"),
      issuer_id: ENV.fetch("CYB_ASC_ISSUER_ID"),
      key: File.read(ENV.fetch("CYB_ASC_KEY_PATH"))
    )
    Spaceship::ConnectAPI.token = token
    rows = Spaceship::ConnectAPI::Certificate.all
    UI.message "Found #{rows.size} cert(s) on the account:"
    rows.each do |c|
      UI.message "  #{c.certificate_type.to_s.ljust(28)} id=#{c.id} name=#{c.name.inspect} expires=#{c.expiration_date}"
    end
  end

  desc "DANGEROUS: revoke every Apple Distribution cert by id. Pass `ids:abc,def,ghi`. Only use to clean up orphans created by failed match runs."
  lane :revoke_certs do |options|
    ids = (options[:ids] || "").split(",").map(&:strip).reject(&:empty?)
    UI.user_error!("Pass ids:abc,def,ghi") if ids.empty?
    require "spaceship"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("CYB_ASC_KEY_ID"),
      issuer_id: ENV.fetch("CYB_ASC_ISSUER_ID"),
      key: File.read(ENV.fetch("CYB_ASC_KEY_PATH"))
    )
    Spaceship::ConnectAPI.token = token
    all_certs = Spaceship::ConnectAPI::Certificate.all
    ids.each do |id|
      cert = all_certs.find { |c| c.id == id }
      if cert.nil?
        UI.important "No cert with id=#{id} found — skipping"
        next
      end
      UI.message "Revoking cert id=#{id} (#{cert.certificate_type} #{cert.name.inspect})"
      cert.delete!
    end
    UI.success "Revoked #{ids.size} cert(s)."
  end

  desc "One-time: create + upload an App Store distribution cert + provisioning profile to the certs repo. Run once per Apple Developer account."
  lane :bootstrap_signing do
    # Only the App Store distribution cert goes through match — Xcode's
    # automatic signing handles Development certs locally for `pnpm open:ios`.
    # Apple caps individual accounts at one active Development cert, so trying
    # to also do `match development` here trips "You already have a current
    # Development certificate" when the user already has one from Xcode.
    #
    # `api_key:` is optional — if set, match skips the interactive Apple ID
    # 2FA prompt. Passing it explicitly (rather than letting match auto-detect
    # from env) avoids the "invalid number: '-----BEGIN'" JSON-parse error you
    # get when match auto-detection picks up a .p8 path and tries to read it
    # as a JSON config file.
    match(
      type: "appstore",
      readonly: false,
      api_key: asc_api_key_or_nil,
      keychain_password: runner_keychain_password,
    )
  end

  desc "Pull signing material from the certs repo without creating anything new. Safe to run on any machine / CI."
  lane :certs do
    match(
      type: "appstore",
      readonly: true,
      api_key: asc_api_key_or_nil,
      keychain_password: runner_keychain_password,
    )
  end

  desc "Bump CURRENT_PROJECT_VERSION to the commit count on HEAD. Monotonic on a linear-history repo, no network round-trip — avoids the ASC SSL flakes that latest_testflight_build_number used to throw on every other run. Must be a strictly greater number than the highest already on TestFlight; that holds as long as commits-on-main only goes up, which is the project's normal cadence (merges count as commits)."
  lane :bump_build do
    # `git rev-list --count HEAD` is deterministic and doesn't depend on a
    # working tree state. We run fastlane from apps/mobile/ios so back up
    # to the repo root for the count.
    count = `git -C "#{File.expand_path('../../../..', __dir__)}" rev-list --count HEAD`.strip.to_i
    UI.user_error!("git rev-list returned 0 — bump_build can't determine a build number") if count.zero?
    UI.message("bump_build: setting CURRENT_PROJECT_VERSION = #{count} (commits on HEAD)")
    increment_build_number(
      build_number: count,
      xcodeproj: "App/App.xcodeproj"
    )
  end

  desc "Upload dSYM debug symbols to self-hosted Sentry so native iOS crashes get symbolicated. No-op when SENTRY_AUTH_TOKEN isn't set so dev / unconfigured machines don't fail. Called automatically from `beta` post-gym; expose as its own lane so a missed upload can be re-run without rebuilding."
  private_lane :upload_dsyms_to_sentry do
    unless ENV["SENTRY_AUTH_TOKEN"]
      UI.important "SENTRY_AUTH_TOKEN not set — skipping Sentry dSYM upload."
      next
    end
    dsym = lane_context[SharedValues::DSYM_OUTPUT_PATH]
    if dsym.nil? || !File.exist?(dsym)
      UI.important "No dSYM at lane_context[:DSYM_OUTPUT_PATH] — skipping Sentry upload."
      next
    end
    sentry_debug_files_upload(
      url: ENV["SENTRY_URL"] || "https://sentry-cyb.work.ripley.cloud",
      auth_token: ENV["SENTRY_AUTH_TOKEN"],
      org_slug: ENV["SENTRY_ORG"] || "cyb",
      project_slug: ENV["SENTRY_PROJECT_MOBILE"] || "cyb-capacitor",
      path: dsym,
      # The Capacitor wrapper's Swift surface is tiny; symbol names
      # alone are enough for stack traces. Skip source upload to keep
      # the artifact small and avoid checking in build outputs.
      include_sources: false,
    )
  end

  desc "Build a signed Release archive and upload it to TestFlight. Requires ASC API key env vars + a match-provisioned profile."
  lane :beta do
    certs
    # Belt-and-suspenders: re-apply the ACL partition list right before
    # gym. Match's keychain_password parameter is supposed to do this
    # during the import, but observation shows the freshly-imported
    # key's ACL is still empty when codesign runs, tripping
    # errSecInternalComponent. Re-applying here costs nothing and is
    # idempotent.
    pwd = runner_keychain_password
    if pwd
      sh(
        "security", "set-key-partition-list",
        "-S", "apple-tool:,apple:,codesign:",
        "-s",
        "-k", pwd,
        File.expand_path("~/Library/Keychains/login.keychain-db"),
        log: false,
        error_callback: ->(_) {
          UI.important("set-key-partition-list returned non-zero; codesign may still trip errSecInternalComponent")
        },
      )
    end
    bump_build
    gym(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "CookYourBooks.ipa",
      clean: true
    )
    # Upload dSYMs to Sentry before pilot so a TestFlight upload failure
    # doesn't strand the symbols. Sentry symbolicates by dSYM UUID; the
    # dSYMs don't need to be tied to any particular release to be
    # useful — every future crash matching these UUIDs gets
    # symbolicated automatically.
    upload_dsyms_to_sentry
    # Pilot in two passes:
    #   1. Upload the IPA. One-shot — re-running pilot with the same
    #      build number trips altool "bundle version already used", so
    #      we deliberately do NOT retry this step.
    #   2. Distribute to the external group + set the changelog. This
    #      pass polls ASC for processing status, and the poll loop is
    #      where we keep hitting `SSL_read: unexpected eof while reading`
    #      — a mid-stream connection cut on Apple's side that OpenSSL 3
    #      surfaces as an error (1.x silently tolerated it). Separating
    #      the passes lets us retry just the flaky one without
    #      re-uploading. `distribute_only: true` skips upload and only
    #      attaches the already-uploaded build to the configured groups.
    pilot(
      api_key: asc_api_key,
      ipa: "build/CookYourBooks.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )

    # Give ASC a chance to ingest the upload before distribute_only's
    # `Build.find` runs — without this, pass 2 routinely raises "Could
    # not find build" because the binary is still queued behind Apple's
    # ingestion pipeline.
    UI.message("Sleeping 60s before pilot distribute pass to let ASC ingest the upload")
    sleep 60

    build_number_for_distribute = lane_context[SharedValues::BUILD_NUMBER].to_s
    distribute_attempts = 0
    begin
      distribute_attempts += 1
      pilot(
        api_key: asc_api_key,
        distribute_only: true,
        # distribute_only skips IPA upload, so pilot can't infer the
        # bundle id / platform from the file. Pass both explicitly,
        # otherwise pilot drops into an interactive prompt and crashes
        # in CI with "Could not retrieve response as fastlane runs in
        # non-interactive mode".
        app_identifier: "app.cookyourbooks",
        app_platform: "ios",
        app_version: get_version_number(xcodeproj: "App/App.xcodeproj", target: "App"),
        build_number: build_number_for_distribute,
        # Attach every build to the external "Friends & Family" group so
        # once Apple approves the first build in a version, subsequent
        # builds reach external testers automatically without another
        # ASC click. First-build-in-version still needs Beta App Review;
        # the group attachment is what queues it up.
        distribute_external: true,
        notify_external_testers: true,
        groups: ["Friends & Family"],
        changelog: ENV["BETA_CHANGELOG"] || "Internal build",
      )
    rescue => e
      msg = e.message.to_s
      transient = msg.include?("SSL_read") ||
                  msg.include?("unexpected eof") ||
                  msg.include?("ECONNRESET") ||
                  msg.include?("execution expired") ||
                  msg.include?("Could not find build")
      if transient && distribute_attempts < 4
        UI.important("pilot distribute attempt #{distribute_attempts} hit transient ASC failure (#{msg.lines.first&.strip}); retrying in 60s")
        sleep 60
        retry
      end
      raise
    end
  end

  desc "Re-upload dSYMs to Sentry without rebuilding. Pass `path:/Library/...App.xcarchive/dSYMs` to target a specific archive; otherwise grabs the most recent gym output or the newest Xcode archive on disk."
  lane :upload_dsyms do |options|
    if options[:path]
      lane_context[SharedValues::DSYM_OUTPUT_PATH] = options[:path]
    elsif lane_context[SharedValues::DSYM_OUTPUT_PATH].nil?
      archive = Dir["#{ENV['HOME']}/Library/Developer/Xcode/Archives/**/*.xcarchive"]
                  .max_by { |p| File.mtime(p) }
      UI.user_error!("No `path:` given and no Xcode archives found in ~/Library/Developer/Xcode/Archives") unless archive
      dsym_dir = File.join(archive, "dSYMs")
      UI.user_error!("Archive #{archive} has no dSYMs dir") unless File.directory?(dsym_dir)
      lane_context[SharedValues::DSYM_OUTPUT_PATH] = dsym_dir
    end
    upload_dsyms_to_sentry
  end

  desc "Build + upload to TestFlight + submit the build for App Store review. Use only when you actually want a public release."
  lane :release do
    beta
    deliver(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: false,  # Hold the release after approval — flip in ASC manually.
      force: true,               # Skip the HTML preview prompt.
      skip_screenshots: true,    # Manage screenshots in ASC by hand until we automate it.
      skip_metadata: true,       # Same — metadata stays in ASC for now.
      precheck_include_in_app_purchases: false
    )
  end
end
