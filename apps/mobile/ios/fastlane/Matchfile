git_url("git@github.com:jon-bell/cookyourbooks-certs.git")
git_branch("main")
storage_mode("git")

# Default to App Store distribution profiles — `fastlane match development`
# pulls dev profiles instead when working on a new dev machine.
type("appstore")

# The Share Extension target (Share to CookYourBooks) ships as its own
# bundle id and needs its own provisioning profile.
app_identifier(["app.cookyourbooks", "app.cookyourbooks.ShareExtension"])
username(ENV["FASTLANE_APPLE_ID"]) if ENV["FASTLANE_APPLE_ID"]
