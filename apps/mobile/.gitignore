# We DO commit the ios/ and android/ native project shells so that signing
# config, AppDelegate customizations, asset catalogs, and fastlane setup live
# in one place. Build artifacts (Pods/, build/, DerivedData/, the generated
# capacitor.config.json) are excluded by the platform-level .gitignore that
# `cap add` creates inside each directory.

# Capacitor transient state
.capacitor/

# Bundler vendored gems (Gemfile / Gemfile.lock are committed; the
# gem payload they install isn't — `bundle install` materializes it).
ios/vendor/
ios/.bundle/

# Fastlane local-only state
ios/fastlane/.env
ios/fastlane/.env.*
!ios/fastlane/.env.example
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots/**/*.png
ios/fastlane/test_output
# Auto-generated by fastlane on every run; lane docs live in apps/mobile/README.md.
ios/fastlane/README.md
ios/build/

# App Store Connect API key — never commit the .p8 file, even by accident.
*.p8
