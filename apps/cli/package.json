{
  "name": "@cookyourbooks/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Command-line client for CookYourBooks. Mints no tokens itself — paste one created in the web or mobile app.",
  "type": "module",
  "bin": {
    "cyb": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
