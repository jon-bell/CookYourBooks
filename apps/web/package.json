    "@dnd-kit/utilities": "^3.2.2",
    "@cookyourbooks/domain": "workspace:*",
    "@supabase/supabase-js": "^2.46.1",
    "@tanstack/react-query": "^5.62.0",
    "@vlcn.io/crsqlite-wasm": "^0.16.0",
